{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/**/*.js",
    "test/**/*.js",
    "scripts/**/*.js",
    "docs/.vitepress/config.mjs"
  ],
  "project": [
    "src/**/*.js",
    "test/**/*.js",
    "scripts/**/*.js",
    "docs/.vitepress/**/*.{js,mjs}",
    "!test/fixtures/**"
  ],
  "ignoreDependencies": [
    "zod",
    "bun-types",
    "mermaid",
    "@huggingface/transformers",
    "onnxruntime-node",
    "onnxruntime-web"
  ]
}
