{
  "title": "apple-docs · Web",
  "uid": "apple-docs-web",
  "schemaVersion": 39,
  "tags": ["apple-docs", "web"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "constant",
        "query": "apple-docs-web",
        "current": { "value": "apple-docs-web", "text": "apple-docs-web" },
        "hide": 2
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request latency (p50 / p95 / p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(apple_docs_web_request_latency_ms_bucket{job=\"$job\"}[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(apple_docs_web_request_latency_ms_bucket{job=\"$job\"}[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(apple_docs_web_request_latency_ms_bucket{job=\"$job\"}[5m])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "type": "timeseries",
      "title": "Requests/sec by route + status class",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "sum by (route, status) (rate(apple_docs_web_requests_total{job=\"$job\"}[1m]))", "legendFormat": "{{route}} · {{status}}" }
      ]
    },
    {
      "type": "stat",
      "title": "Rate-limiter bucket inventory",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "apple_docs_web_rate_limit_buckets{job=\"$job\"}", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "type": "timeseries",
      "title": "Cache byte usage",
      "gridPos": { "h": 6, "w": 10, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "apple_docs_web_cache_bytes{job=\"$job\"}", "legendFormat": "{{cache}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "type": "timeseries",
      "title": "Reader-pool pending (per pool)",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "apple_docs_reader_pool_pending{job=\"$job\"}", "legendFormat": "pending · {{pool}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Reader-pool timeouts + backpressure (per pool)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "rate(apple_docs_reader_pool_timeouts_total{job=\"$job\"}[1m])", "legendFormat": "timeouts · {{pool}}" },
        { "expr": "rate(apple_docs_reader_pool_backpressure_rejects_total{job=\"$job\"}[1m])", "legendFormat": "backpressure rejects · {{pool}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Event-loop lag (quantiles, gauge)",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "apple_docs_event_loop_lag_ms{job=\"$job\",quantile=\"0.5\"}", "legendFormat": "p50" },
        { "expr": "apple_docs_event_loop_lag_ms{job=\"$job\",quantile=\"0.95\"}", "legendFormat": "p95" },
        { "expr": "apple_docs_event_loop_lag_ms{job=\"$job\",quantile=\"0.99\"}", "legendFormat": "p99" },
        { "expr": "apple_docs_event_loop_lag_ms{job=\"$job\",quantile=\"max\"}", "legendFormat": "max" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "type": "timeseries",
      "title": "Process RSS + JS heap",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "apple_docs_process_rss_bytes{job=\"$job\"}", "legendFormat": "RSS" },
        { "expr": "apple_docs_process_heap_bytes{job=\"$job\",kind=\"used\"}", "legendFormat": "heap used" },
        { "expr": "apple_docs_process_heap_bytes{job=\"$job\",kind=\"total\"}", "legendFormat": "heap total" },
        { "expr": "apple_docs_process_external_bytes{job=\"$job\"}", "legendFormat": "external" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
