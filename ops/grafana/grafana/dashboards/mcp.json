{
  "title": "apple-docs · MCP",
  "uid": "apple-docs-mcp",
  "schemaVersion": 39,
  "tags": ["apple-docs", "mcp"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "constant",
        "query": "apple-docs-mcp",
        "current": { "value": "apple-docs-mcp", "text": "apple-docs-mcp" },
        "hide": 2
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Heavy-tool semaphore (active / waiting / rejected/sec)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "apple_docs_heavy_semaphore_active{job=\"$job\"}", "legendFormat": "active" },
        { "expr": "apple_docs_heavy_semaphore_waiting{job=\"$job\"}", "legendFormat": "waiting" },
        { "expr": "rate(apple_docs_heavy_semaphore_rejected_total{job=\"$job\"}[1m])", "legendFormat": "rejected/sec" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Response-cache hit ratio (per tool)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (cache) (rate(apple_docs_mcp_cache_hits_total{job=\"$job\"}[5m])) / clamp_min(sum by (cache) (rate(apple_docs_mcp_cache_hits_total{job=\"$job\"}[5m]) + rate(apple_docs_mcp_cache_misses_total{job=\"$job\"}[5m])), 0.000001)",
          "legendFormat": "{{cache}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "type": "timeseries",
      "title": "Response-cache size (entries per tool)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "apple_docs_mcp_cache_size{job=\"$job\"}", "legendFormat": "{{cache}}" },
        { "expr": "apple_docs_mcp_cache_capacity{job=\"$job\"}", "legendFormat": "capacity · {{cache}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "type": "timeseries",
      "title": "Markdown render-cache",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "rate(apple_docs_mcp_markdown_cache_hits_total{job=\"$job\"}[1m])", "legendFormat": "hits/sec" },
        { "expr": "rate(apple_docs_mcp_markdown_cache_misses_total{job=\"$job\"}[1m])", "legendFormat": "misses/sec" },
        { "expr": "rate(apple_docs_mcp_markdown_cache_evictions_total{job=\"$job\"}[1m])", "legendFormat": "evictions/sec" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Reader-pool pending (per pool)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "apple_docs_reader_pool_pending{job=\"$job\"}", "legendFormat": "pending · {{pool}}" },
        { "expr": "apple_docs_reader_pool_active{job=\"$job\"}", "legendFormat": "active · {{pool}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Reader-pool timeouts + backpressure (per pool)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "rate(apple_docs_reader_pool_timeouts_total{job=\"$job\"}[1m])", "legendFormat": "timeouts · {{pool}}" },
        { "expr": "rate(apple_docs_reader_pool_backpressure_rejects_total{job=\"$job\"}[1m])", "legendFormat": "backpressure rejects · {{pool}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Process RSS",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "apple_docs_process_rss_bytes{job=\"$job\"}", "legendFormat": "RSS" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
