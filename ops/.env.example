# apple-docs reference deployment — operator config
#
# Copy this file to `ops/.env` and edit every value. `ops/.env` is gitignored.
# The install and render scripts source this file; every variable is required.

# --- Identity -----------------------------------------------------------------

# macOS user that owns the daemons (output of `id -un`).
USER_NAME=you

# Absolute path to this apple-docs checkout.
REPO_DIR=/Users/you/Developer/apple-docs

# Absolute path to the ops/ directory (usually $REPO_DIR/ops).
OPS_DIR=/Users/you/Developer/apple-docs/ops

# Apple-docs data directory. Must match APPLE_DOCS_HOME set below.
DATA_DIR=/Users/you/.apple-docs

# Path to the Bun binary. `which bun` will tell you.
BUN_BIN=/Users/you/.bun/bin/bun

# Prefix for launchd labels and the sudoers drop-in. Reverse-DNS is
# conventional, but any prefix works. The templates append `.proxy`, `.web`,
# `.mcp`, `.cloudflared.<web|mcp>`.
LABEL_PREFIX=local.apple-docs

# --- Network ------------------------------------------------------------------

# Ports the proxy listens on (public-facing, stable).
WEB_PORT=3030
MCP_PORT=3031

# Ports the bun apps listen on (private backend).
WEB_BACKEND_PORT=3130
MCP_BACKEND_PORT=3131

# Public hostnames served by the tunnels.
PUBLIC_WEB_HOST=apple-docs.example.com
PUBLIC_MCP_HOST=apple-docs-mcp.example.com

# Caddy admin API listen address.
CADDY_ADMIN_ADDR=127.0.0.1:2019

# Path to the prebuilt static site Caddy serves with `file_server`. Generated
# by `apple-docs web build --incremental`. Leave unset to default to
# ${REPO_DIR}/dist/web.
# STATIC_DIR=/Users/you/Developer/apple-docs/dist/web

# --- Cloudflare Tunnel --------------------------------------------------------

# Tunnel names (not UUIDs). Create with `cloudflared tunnel create <name>`.
TUNNEL_NAME_WEB=apple-docs
TUNNEL_NAME_MCP=apple-docs-mcp

# Absolute paths to the tunnel credentials JSON files. `cloudflared tunnel
# create` prints these paths and writes `<UUID>.json` by default.
CLOUDFLARED_CREDENTIALS_FILE_WEB=/Users/you/.cloudflared/REPLACE_WEB_UUID.json
CLOUDFLARED_CREDENTIALS_FILE_MCP=/Users/you/.cloudflared/REPLACE_MCP_UUID.json

# Absolute path to the cloudflared binary.
CLOUDFLARED_BIN=/Users/you/bin/cloudflared

# --- Optional tuning ----------------------------------------------------------

# Scale every default MCP cache capacity (response cache + markdown cache) by
# this multiplier. `1` keeps laptop-sized defaults (~40 MB steady state). `5`
# is a good starting point for a dedicated server (~200 MB). Leave unset to
# default to `1`.
# APPLE_DOCS_MCP_CACHE_SCALE=1

# --- Watchdog -----------------------------------------------------------------
#
# `ops/bin/watchdog.sh` runs as ${LABEL_PREFIX}.watchdog and protects against
# event-loop wedges, slow accumulation, and RSS runaway. All knobs are optional.
#
# Probe cadence and budget. 3 fails × 30s = ~90s detection, plus the kickstart
# itself adds ~5–15s, so the user-visible blast radius is well under 5 min.
# WATCHDOG_INTERVAL=30
# WATCHDOG_FAILS=3
# WATCHDOG_TIMEOUT=5
#
# Per-backend cooldown between kickstarts (seconds). Prevents restart storms.
# WATCHDOG_COOLDOWN=300
#
# RSS backstops (megabytes). Set to 0 to disable. Web is noisy because of the
# SQLite mmap (~3.7 GB) — keep generous headroom above the healthy baseline.
# WATCHDOG_WEB_RSS_LIMIT_MB=3072
# WATCHDOG_MCP_RSS_LIMIT_MB=8192
#
# Optional preventive daily restart at this local-time hour (00..23). Leave
# unset to disable. Targets is comma-separated (web,mcp,both,...) and defaults
# to `web` since web is the only daemon that has shown slow accumulation.
# WATCHDOG_DAILY_RESTART_HOUR=4
# WATCHDOG_DAILY_RESTART_TARGETS=web

# --- Migration helpers --------------------------------------------------------

# Comma-separated list of legacy launchd labels (system/<label>) that
# install-daemons.sh should bootout and remove before installing the new
# plists. Useful when switching label schemes — e.g. migrating from an
# external ops directory that used a different prefix.
# LEGACY_LAUNCHD_LABELS=old.prefix.service.foo,old.prefix.service.bar

# Comma-separated list of filesystem paths that are symlinks to $OPS_DIR,
# left behind as compatibility shims during a migration. install-daemons.sh
# removes each one at the end of a successful run. Safe on repeat invocations
# (only removes paths that are still symlinks pointing at $OPS_DIR).
# COMPAT_SYMLINKS=/Users/you/Developer/apple-docs-ops
