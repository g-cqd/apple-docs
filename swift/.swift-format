{
  "version": 1,
  "lineLength": 120,
  "indentation": { "spaces": 2 },
  "indentConditionalCompilationBlocks": false,
  "maximumBlankLines": 1,
  "respectsExistingLineBreaks": true,
  "rules": {
    "DoNotUseSemicolons": false,
    "OrderedImports": false,
    "AlwaysUseLowerCamelCase": false
  }
}
