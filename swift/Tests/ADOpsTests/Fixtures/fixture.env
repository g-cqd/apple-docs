# Canonical ops/.env for the ADOps byte-parity gate. Values are fixed so the
# JS render output is deterministic. APPLE_DOCS_NATIVE is intentionally left
# unset (empty) to exercise the allowlisted-but-empty -> literal passthrough.
USER_NAME=everest
REPO_DIR=/Users/everest/Developer/apple-docs
OPS_DIR=/Users/everest/Developer/apple-docs/ops
DATA_DIR=/Users/everest/.apple-docs
BUN_BIN=/Users/everest/.bun/bin/bun
LABEL_PREFIX=mt.everest.apple-docs
WEB_PORT=3030
MCP_PORT=3031
WEB_BACKEND_PORT=3130
MCP_BACKEND_PORT=3131
PUBLIC_WEB_HOST=apple-docs.example.com
PUBLIC_MCP_HOST=apple-docs-mcp.example.com
CADDY_ADMIN_ADDR=127.0.0.1:2019
TUNNEL_NAME_WEB=apple-docs
TUNNEL_NAME_MCP=apple-docs-mcp
CLOUDFLARED_CREDENTIALS_FILE_WEB=/Users/everest/.cloudflared/web-uuid.json
CLOUDFLARED_CREDENTIALS_FILE_MCP=/Users/everest/.cloudflared/mcp-uuid.json
CLOUDFLARED_BIN=/Users/everest/bin/cloudflared
